# =========================================================
# Job Tracker - Environment Variables
# Copy this file to `.env` and fill in values for your own
# Supabase project when you self-host.
# =========================================================

# Supabase project URL (e.g. https://xxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable (anon) key - safe to expose in browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase service role key, for trusted server routes only
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project ref (used by types generator only)
SUPABASE_PROJECT_ID=

# App branding
NEXT_PUBLIC_APP_NAME="Job Tracker"

# Storage bucket names (must match buckets in your Supabase Storage)
NEXT_PUBLIC_STORAGE_BUCKET_DOCUMENTS=documents
NEXT_PUBLIC_STORAGE_BUCKET_AVATARS=avatars
NEXT_PUBLIC_STORAGE_BUCKET_COMPANY_LOGOS=company-logos
