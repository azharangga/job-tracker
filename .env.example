# =========================================================
# Job Tracker — Environment Variables
# Copy this file to `.env` and fill in values for your own
# Supabase project when you self-host. During Lovable Cloud
# development these values are auto-injected.
# =========================================================

# Supabase project URL (e.g. https://xxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Supabase publishable (anon) key — safe to expose in browser
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase project ref (used by types generator only)
VITE_SUPABASE_PROJECT_ID=

# App branding
VITE_APP_NAME="Job Tracker"

# Storage bucket names (must match buckets in your Supabase Storage)
VITE_STORAGE_BUCKET_DOCUMENTS=documents
VITE_STORAGE_BUCKET_AVATARS=avatars
VITE_STORAGE_BUCKET_COMPANY_LOGOS=company-logos
